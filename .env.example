# ydelta-crankers configuration. Copy to `.env` for local dev; on
# Railway/CI inject these as env vars directly.

# ─── Network ─────────────────────────────────────────────────────────
NETWORK=mainnet                          # localhost | mainnet
RPC_URL=https://api.mainnet-beta.solana.com
# YDELTA_PROGRAM_ID=HfYCWUgFuUbuzZTeQAAGzVkXw2uFM51QRoDfhFV8vyCj   # override for non-canonical deploys
MARGINFI_PROGRAM_ID=MFv2hWf31Z9kbCa1snEPYctwafyhdvnV7FZnsebVacA
MARGINFI_GROUP=4qp6Fx6tnZkY5Wropq9wUYgtFxXKwE6viZxFHg3rdAG8

# ─── Fee-payer keypair ───────────────────────────────────────────────
# Set exactly ONE of the two below (both = startup error).
# FEE_PAYER_KEYPAIR=/secrets/fee-payer.json        # solana-CLI JSON (64-byte array)
FEE_PAYER_KEYPAIR_BASE58=                          # base58 of the raw 64-byte secret
# FEE_PAYER_PUBKEY=                                 # optional: assert the loaded key matches

# ─── Handlers ────────────────────────────────────────────────────────
PROMOTER_ENABLED=true
CLAIMER_ENABLED=true
LIQUIDATOR_ENABLED=true
MATCH_CRANKER_ENABLED=true               # resolves crossed-at-rest books (tag 43)
CURATOR_FEE_CLAIMER_ENABLED=false        # opt-in; requires CURATOR_KEYPAIRS_JSON

PROMOTER_INTERVAL_SEC=5
CLAIMER_INTERVAL_SEC=30
LIQUIDATOR_INTERVAL_SEC=10
MATCH_CRANKER_INTERVAL_SEC=15
MATCH_CRANKER_MAX_FILLS=8                 # crosses per MatchCrank call (0 → 1 on-chain)
CURATOR_FEE_CLAIMER_INTERVAL_SEC=3600

# Base58 secret keys (JSON array, or a bare string for one curator). Only
# the curator-fee-claimer uses these. Leave unset otherwise.
# CURATOR_KEYPAIRS_JSON=["5J8b...","9Hx2..."]

# ─── Thresholds ──────────────────────────────────────────────────────
MIN_LIQUIDATION_PROFIT_ATOMS=1000000     # skip liquidations whose keeper bonus is below this
MATURITY_EXTRA_BUFFER_SEC=30             # clock-skew margin past the per-market grace period
MIN_CURATOR_FEE_CLAIM_ATOMS=100000       # skip curator-fee claims below this
BANKS_REFRESH_SEC=300                    # re-discover banks/markets from chain

# ─── Tx + balances ───────────────────────────────────────────────────
PRIORITY_FEE_MICRO_LAMPORTS=1000         # 0 disables; CU limit is fixed at 1.4M per tx
MIN_SIGNER_BALANCE_LAMPORTS=50000000     # pause all handlers below this (0.05 SOL)

# ─── Observability ───────────────────────────────────────────────────
# Bank metadata + liquidator ATAs are discovered from chain at boot — but
# you must FUND the fee-payer's debt-mint ATA before the liquidator can settle.
METRICS_BIND=0.0.0.0:9091                # Prometheus /metrics
HEALTH_BIND=0.0.0.0:8080                 # /healthz + /readyz
RUST_LOG=info,ydelta_crankers=info
# LOG_FORMAT=json                          # structured logs
