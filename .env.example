# ───────────────────────────────────────────────────────────────────
# ydelta-crankers configuration
#
# Local dev: copy to `.env` and fill in. Railway / GitHub Actions inject
# these as env vars directly — no `.env` on the host.
# Keypair files are referenced by path; mount them outside the repo.
# ───────────────────────────────────────────────────────────────────

# ─── Network ─────────────────────────────────────────────────────────
# yDelta deploys to localhost (solana-test-validator) and mainnet only.
# The cranker discovers every piece of state it needs directly from the
# chain via getProgramAccounts — no indexer endpoint required.
NETWORK=mainnet                          # localhost | mainnet
RPC_URL=https://api.mainnet-beta.solana.com

# Override only if pointing at a non-canonical deploy (e.g. a localhost
# fork running with a different program id).
# YDELTA_PROGRAM_ID=9Tcnk3xQKXeoSdY7ovTyGtGGFbBxraQR7TDhRE2UyXRT

MARGINFI_PROGRAM_ID=MFv2hWf31Z9kbCa1snEPYctwafyJVoG1uJL6FtSeZD8
MARGINFI_GROUP=4qp6Fx6tnZkY5Wropq9wUYgtFxXKwE6viZxFHg3rdAG8

# ─── Signers ────────────────────────────────────────────────────────
# Each keypair (fee payer + curators) accepts EITHER a file path OR an
# inline base58 secret. Pick one per role.
#
#   path:       FEE_PAYER_KEYPAIR=/secrets/fee-payer.json
#               Solana-CLI-format JSON file (64-byte array). Best when
#               the PaaS supports first-class secret files.
#
#   inline:     FEE_PAYER_KEYPAIR_BASE58=5J8b...
#               Base58 encoding of the raw 64-byte secret key. Best on
#               PaaS that only supports env vars (e.g. Railway). The
#               bot's `Config` Debug impl redacts this value, so it
#               won't leak via `tracing::error!(?cfg)`.
#
# Setting both for the same role is a config error and the bot refuses
# to start. The optional `FEE_PAYER_PUBKEY` below asserts the loaded
# key matches — strongly recommended on mainnet to catch swap-ups.
#
# Inline (Railway-friendly) is the active default below; uncomment the
# path line + comment the BASE58 line if you have a secret-files
# system. Encode existing CLI keypairs via:
#   yarn setup:encode-keypairs -- --fee-payer ~/.config/solana/id.json
# (run from the ydelta/ root).
# FEE_PAYER_KEYPAIR=/secrets/fee-payer.json
FEE_PAYER_KEYPAIR_BASE58=
# FEE_PAYER_PUBKEY=EokNERAAaWorYsqMqgNhVHbyNmQoGDzEuVpbbEsCtK3a

# Per-(vault, profile_id) curator signers. JSON array.
#
# Each entry takes EITHER `keypair` (file path) OR `keypair_base58`
# (inline). Setting both on the same entry is a config error.
#
# Inline is shown below as the default — generate the base58 strings via:
#   yarn setup:encode-keypairs -- --curator-map <path-to-curator-map.json>
# (run from the ydelta/ root; the curator-map file is the output of
#  `yarn setup:risk-profiles`).
#
# Rate modes (per profile):
#   - Static:  set `target_rate_bps`. Bot quotes that exact rate.
#   - Dynamic: set `target_rate_alpha_bps`. Bot quotes
#       `marginfi_supply_apr + alpha/10000 × (marginfi_borrow_apr - marginfi_supply_apr)`.
#       Provide `target_rate_fallback_bps` (or a `target_rate_bps` to
#       reuse as fallback) for when the bank read fails.
#
# Optional per-entry `max_exposure_atoms` sets the per-(vault,
# profile, market) cap used when the keeper auto-claims a seat
# (only consulted on the bootstrap path, not for live orders).
# Omitted → `u64::MAX` = effectively uncapped.
#
# CURATORS='[
#   {
#     "global_vault": "VaultPubkey...",
#     "profile_id": 1,
#     "keypair_base58": "5J8b...",            # inline mode (recommended for Railway)
#     "target_rate_alpha_bps": 5000,
#     "target_rate_fallback_bps": 650,
#     "target_term_seconds": 2592000,
#     "markets": ["MarketA...", "MarketB..."],
#     "max_exposure_atoms": 1000000000000     # optional; per-market cap. omit for uncapped.
#   },
#   {
#     "global_vault": "VaultPubkey...",
#     "profile_id": 2,
#     "keypair": "/secrets/curator-2.json",   # path mode (when secret-files are available)
#     "target_rate_bps": 750,
#     "target_term_seconds": 604800,
#     "markets": ["MarketA..."]
#   }
# ]'
CURATORS=[]

# ─── Bank registry & liquidator ATAs ─────────────────────────────────
# Both are discovered automatically — no env vars required.
#
# Banks: at boot the cranker lists markets from the indexer, reads each
#   `MarketFixed` on chain to extract its (debt_bank, collateral_bank)
#   pubkeys, then reads each unique Bank account to populate the rest
#   (liquidity vault, LVA via PDA derivation, oracle keys, token program).
#
# Liquidator ATAs: deterministic PDAs of (fee_payer, mint, token_program).
#   The bot derives them on the fly via `BankInfo::ata_for(fee_payer)`.
#   You DO still need to fund the debt-side ATA(s) with the debt asset
#   (USDC etc.) before the liquidator can settle anything — the bot
#   can't deposit on your behalf. Find the ATA via:
#     `solana spl-token accounts --owner <fee-payer-pubkey>`

# ─── Handler enable flags ────────────────────────────────────────────
PROMOTER_ENABLED=true
CLAIMER_ENABLED=true
LIQUIDATOR_ENABLED=true
POLICY_SYNC_ENABLED=true
CURATOR_KEEPER_ENABLED=true

# ─── Handler intervals (seconds) ─────────────────────────────────────
PROMOTER_INTERVAL_SEC=5
CLAIMER_INTERVAL_SEC=30
LIQUIDATOR_INTERVAL_SEC=10
POLICY_SYNC_INTERVAL_SEC=60
CURATOR_KEEPER_INTERVAL_SEC=60

# ─── Thresholds ──────────────────────────────────────────────────────
# Liquidator skips loans where `outstanding_debt_atoms` is below this.
MIN_LIQUIDATION_PROFIT_ATOMS=1000000

# Curator keeper minimum rate change to trigger a re-quote.
CURATOR_MIN_DELTA_BPS=25

# Curator keeper throttle per (profile, market). Avoids back-of-queue
# churn from over-frequent updates.
CURATOR_MIN_UPDATE_INTERVAL_SEC=300

# Bot waits this many extra seconds past on-chain grace before settling
# matured loans. Lets the indexer catch up to chain state.
MATURITY_EXTRA_BUFFER_SEC=30

# ─── RPC priority fee ────────────────────────────────────────────────
# Micro-lamports per compute unit. 0 disables; ~1000 is a reasonable
# mainnet floor at light congestion. The bot also sets a 1.4M
# compute-unit *limit* per tx (Solana's max), so liquidate txs with
# marginfi CPIs + oracle reads don't get truncated.
PRIORITY_FEE_MICRO_LAMPORTS=1000

# ─── Fee-payer balance bail-out ──────────────────────────────────────
# When the fee-payer wallet drops below this many lamports, the
# supervisor pauses every handler that signs with the fee payer
# (promoter, claimer, liquidator, policy_sync). curator_keeper keeps
# running — it uses per-curator keypairs.
# Default: 50_000_000 lamports = 0.05 SOL.
MIN_SIGNER_BALANCE_LAMPORTS=50000000

# ─── Metrics ─────────────────────────────────────────────────────────
# Prometheus exposition endpoint. /metrics is served on this address.
# Grafana Cloud's hosted Prometheus scrapes a public URL here.
# On Railway, set this to `0.0.0.0:$PORT` so the platform exposes it.
METRICS_BIND=0.0.0.0:9091

# ─── Health endpoints ────────────────────────────────────────────────
# Tiny HTTP server exposing /healthz (always 200 once up) and /readyz
# (503 until bank discovery + ATA bootstrap finish). Wire this into
# Railway's healthcheck (Settings → Healthcheck Path = /healthz, Port
# = whatever you bind here). For k8s use as both liveness + readiness.
HEALTH_BIND=0.0.0.0:8080

# ─── Logging ─────────────────────────────────────────────────────────
RUST_LOG=info,ydelta_crankers=info
# LOG_FORMAT=json   # uncomment for structured logs (Grafana / Railway)
